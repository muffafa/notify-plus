<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      INTERNET is required by React Native dev tooling (Metro) and is harmless in release.
      notify-plus does NOT transmit notification content off-device.
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Required on Android 13+ (API 33) to post our own (re-issued) notifications. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Package visibility (Android 11+ / API 30): declare the Telegram client variants so we can
      resolve their app label and offer "open Telegram". The NotificationListenerService receives
      notifications regardless of <queries>; this is only for PackageManager lookups/launch.
    -->
    <queries>
        <package android:name="org.telegram.messenger" />
        <package android:name="org.telegram.messenger.web" />
        <package android:name="org.telegram.messenger.beta" />
        <package android:name="org.telegram.plus" />
        <package android:name="org.thunderdog.challegram" />
    </queries>

    <application
      android:name=".MainApplication"
      android:label="@string/app_name"
      android:icon="@mipmap/ic_launcher"
      android:roundIcon="@mipmap/ic_launcher_round"
      android:allowBackup="false"
      android:theme="@style/AppTheme"
      android:usesCleartextTraffic="${usesCleartextTraffic}"
      android:supportsRtl="true">

      <!--
        The main activity has NO launcher intent-filter. The launcher entry is provided by one of
        the activity-aliases below, so we can switch the home-screen icon color at runtime by
        enabling exactly one alias and disabling the rest (see NotifyModule.setLauncherIconVariant).
      -->
      <activity
        android:name=".MainActivity"
        android:label="@string/app_name"
        android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
        android:launchMode="singleTask"
        android:windowSoftInputMode="adjustResize"
        android:exported="true" />

      <!-- Launcher icon color variants. EXACTLY ONE is enabled at a time. Orange is the default. -->
      <activity-alias
        android:name=".IconOrange"
        android:enabled="true"
        android:exported="true"
        android:targetActivity=".MainActivity"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round">
        <intent-filter>
          <action android:name="android.intent.action.MAIN" />
          <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
      </activity-alias>

      <activity-alias
        android:name=".IconBlue"
        android:enabled="false"
        android:exported="true"
        android:targetActivity=".MainActivity"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher_blue"
        android:roundIcon="@mipmap/ic_launcher_blue">
        <intent-filter>
          <action android:name="android.intent.action.MAIN" />
          <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
      </activity-alias>

      <activity-alias
        android:name=".IconGreen"
        android:enabled="false"
        android:exported="true"
        android:targetActivity=".MainActivity"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher_green"
        android:roundIcon="@mipmap/ic_launcher_green">
        <intent-filter>
          <action android:name="android.intent.action.MAIN" />
          <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
      </activity-alias>

      <activity-alias
        android:name=".IconRed"
        android:enabled="false"
        android:exported="true"
        android:targetActivity=".MainActivity"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher_red"
        android:roundIcon="@mipmap/ic_launcher_red">
        <intent-filter>
          <action android:name="android.intent.action.MAIN" />
          <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
      </activity-alias>

      <activity-alias
        android:name=".IconPurple"
        android:enabled="false"
        android:exported="true"
        android:targetActivity=".MainActivity"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher_purple"
        android:roundIcon="@mipmap/ic_launcher_purple">
        <intent-filter>
          <action android:name="android.intent.action.MAIN" />
          <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
      </activity-alias>

      <activity-alias
        android:name=".IconSky"
        android:enabled="false"
        android:exported="true"
        android:targetActivity=".MainActivity"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher_sky"
        android:roundIcon="@mipmap/ic_launcher_sky">
        <intent-filter>
          <action android:name="android.intent.action.MAIN" />
          <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
      </activity-alias>

      <activity-alias
        android:name=".IconYellow"
        android:enabled="false"
        android:exported="true"
        android:targetActivity=".MainActivity"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher_yellow"
        android:roundIcon="@mipmap/ic_launcher_yellow">
        <intent-filter>
          <action android:name="android.intent.action.MAIN" />
          <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
      </activity-alias>

      <activity-alias
        android:name=".IconDark"
        android:enabled="false"
        android:exported="true"
        android:targetActivity=".MainActivity"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher_dark"
        android:roundIcon="@mipmap/ic_launcher_dark">
        <intent-filter>
          <action android:name="android.intent.action.MAIN" />
          <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
      </activity-alias>

      <!--
        The notification listener. The OS binds this service when the user grants
        "Notification access". It runs independently of the React Native runtime, so it keeps
        filtering and re-alerting even when the app UI is closed.
      -->
      <service
        android:name=".notify.NotifyListenerService"
        android:label="@string/notification_listener_label"
        android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
        android:exported="false">
        <intent-filter>
          <action android:name="android.service.notification.NotificationListenerService" />
        </intent-filter>
      </service>
    </application>
</manifest>
